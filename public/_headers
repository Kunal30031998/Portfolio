# Cloudflare Pages headers — controls cache + security
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# Default — fast HTML revalidation, secure headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# HTML — never cache long, always revalidate so deploys ship instantly
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Hashed JS/CSS chunks from Vite — immutable for 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static assets — cache 1 day, revalidate
/*.svg
  Cache-Control: public, max-age=86400, must-revalidate
/*.png
  Cache-Control: public, max-age=86400, must-revalidate
/*.jpg
  Cache-Control: public, max-age=86400, must-revalidate
/*.webp
  Cache-Control: public, max-age=86400, must-revalidate

# Audio — large; cache for a week
/*.mp3
  Cache-Control: public, max-age=604800, must-revalidate
  Accept-Ranges: bytes

# PDF — cache for a day
/*.pdf
  Cache-Control: public, max-age=86400, must-revalidate

# Service worker — must always revalidate so updates roll out
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# Robots / sitemap — refresh daily
/robots.txt
  Cache-Control: public, max-age=86400
/sitemap.xml
  Cache-Control: public, max-age=86400
